PORT=4000
CORS_ORIGIN=http://localhost:5173
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Where "Forgot password" on /admin sends the one-time reset code.
ADMIN_EMAIL=

# SMTP used to actually send that email. Any provider's SMTP credentials
# work here (Gmail app password, SendGrid, Mailgun, Resend, AWS SES, ...).
# If left unset, reset codes are printed to the server console instead —
# fine for local dev, not for a real deployment.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
